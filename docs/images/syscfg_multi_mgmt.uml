@startuml
left to right direction

title Evolution Services May Be Shared By\nMultiple Management Programs and Environments

[Evolution\nService] as evo
[Management\nProgram 1] as mgmt1
[Management\nProgram 2] as mgmt2
[Environment 1] as env1
[Environment 2] as env2
[AI Agent 1] as ctrl1
[AI Agent 2] as ctrl2

evo -- env1
evo -- env2
mgmt1 - env1
env2 - mgmt2
env1 -- ctrl1
env2 -- ctrl2

@enduml